{
  "name": "coverage-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Devin Coverage Dashboard — visualizes Devin's autonomous test-coverage patrol on bank-of-devin.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pipeline:snapshot": "tsx pipeline/generate-snapshot.ts",
    "pipeline:seed": "tsx pipeline/seed-demo-data.ts"
  },
  "dependencies": {
    "picomatch": "^4.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/picomatch": "^3.0.1",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitejs/plugin-react": "^4.3.2",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.12",
    "fast-xml-parser": "^4.5.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
